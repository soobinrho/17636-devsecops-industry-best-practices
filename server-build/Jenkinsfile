pipeline {
    agent {
        docker {
            image 'eclipse-temurin:25' 
        }
    }
    stages {
        stage('static-analysis') {
            steps {
                sh 'mvn --version'
            }
        }
        stage('build') {
            steps {
                sh 'mvn --version'
            }
        }
        stage('test') {
            steps {
                sh 'mvn --version'
            }
        }
        stage('deploy') {
            steps {
                sh 'mvn --version'
            }
        }
    }
    post {
        success {
            echo '[INFO] Successful!'
        }
        failure {
            echo '[ERROR] Pipeline has failed!'
        }
    }
}
