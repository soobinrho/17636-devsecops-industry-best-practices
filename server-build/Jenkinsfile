pipeline {
    agent {
        label 'linux && ssh-agent'
    }
    stages {
        stage('Static Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'sonarqube', credentialsId: 'sonarqube-token') {
                    sh '''
                        cd spring-petclinic
                        ./mvnw clean install
                        ./mvnw org.sonarsource.scanner.maven:sonar-maven-plugin:sonar -Dsonar.projectKey=petclinic
                    '''
                }
            }
        }
        stage('Build') {
            steps {
                sh '''
                    cd spring-petclinic
                    ./mvnw spring-boot:start
                '''
            }
        }
        stage('Vulnerability Scanning') {
            steps {
                sh '''
                    pwd
                    zaproxy -cmd -quickurl http://localhost:8080 -quickprogress -port 9999 -quickout /home/jenkins/agent/workspace/zap-report-petclinic.html -config reports.template=modern
                '''
            }
        }
        stage('Report Generation for Vulnerability Scanning') {
            steps {
                publishHTML (
                    target : [
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: false,
                        reportDir: '/home/jenkins/agent/workspace',
                        reportFiles: 'zap-report-petclinic.html',
                        reportName: 'ZAP Vulnerability Scanning Results',
                        reportTitles: 'ZAP Vulnerability Scanning Results'
                    ]
                )
            }
        }

        stage('Deploy') {
            steps {
                sh 'echo deploying...'
            }
        }
    }
    post {
        always {
            sh '''
                cd spring-petclinic
                ./mvnw spring-boot:stop
            '''
        }
        success {
            echo '[INFO] Successful!'
        }
        failure {
            echo '[ERROR] Pipeline has failed!'
        }
    }
}
