pipeline {
    agent {
        label 'linux && ssh-agent'
    }
    stages {
        stage('Static Analysis') {
            steps {
                withSonarQubeEnv(installationName: 'sonarqube', credentialsId: 'sonarqube-token') {
                    sh '''
                        git submodule update --init --recursive
                        cd spring-petclinic
                        ./mvnw clean install
                        ./mvnw org.sonarsource.scanner.maven:sonar-maven-plugin:sonar -Dsonar.projectKey=petclinic
                    '''
                }
            }
        }
        // stage('Build') {
        //     steps {
        //         sh '''
        //             cd spring-petclinic
        //             ./mvnw spring-boot:start
        //         '''
        //     }
        // }
        // stage('Penetration Testing') {
        //     steps {
        //         // Reference: https://www.zaproxy.org/blog/2026-06-29-even-more-owasp-ptk-integration-with-zap/
        //         sh('zaproxy -cmd -autorun /home/jenkins/agent/workspace/zap-owasp-penetration-testing-kit.yaml -port 9999')
        //     }
        // }
        stage('Prod Deployment') {
            environment {
                PROD_INVENTORY = credentials('17636-prod-ansible-inventory') 
            }
            steps {
                ansiblePlaybook(
                    credentialsId: '17636-prod-ssh-key',
                    disableHostKeyChecking: true,
                    inventory: '${PROD_INVENTORY}',
                    playbook: '/home/jenkins/agent/workspace/17636-playbook.yaml',
                    extraVars: [ git_hash: "${env.GIT_COMMIT}" ]
                )
            }
        }
    }
    post {
        success {
            publishHTML (
                target : [
                    allowMissing: false,
                    alwaysLinkToLastBuild: true,
                    keepAll: false,
                    reportDir: '/home/jenkins/agent/workspace',
                    reportFiles: 'petclinic.html',
                    reportName: 'Vulnerability Scanning and Penetration Testing',
                    reportTitles: 'Vulnerability Scanning and Penetration Testing'
                ]
            )
        }
    }
}
