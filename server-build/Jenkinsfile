pipeline {
    agent {
        docker {
            image 'eclipse-temurin:25' 
        }
    }
    stages {
        stage('static-analysis') {
            environment {
                scannerHome = tool 'sonarqube';
            }
            steps {
                withSonarQubeEnv(credentialsId: 'sonarqube-token', installationName: 'sonarqube') {
                    sh "${scannerHome}/bin/sonar-scanner"
                }
            }
        }
        stage('build') {
            steps {
                sh 'pwd && whoami'
            }
        }
        stage('test') {
            steps {
                sh 'ls -l'
            }
        }
        stage('deploy') {
            steps {
                sh 'echo yes!'
            }
        }
    }
    post {
        success {
            echo '[INFO] Successful!'
        }
        failure {
            echo '[ERROR] Pipeline has failed!'
        }
    }
}
